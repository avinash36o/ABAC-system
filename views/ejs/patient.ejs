<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Patient Dashboard</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>

  <link rel="stylesheet" href="/patient.css" />
</head>

<body>

  <!-- Navbar -->
  <div class="navbar">
    <h2>Patient Dashboard</h2>
    <a href="/user/logout" class="logout-btn">Logout</a>
  </div>

  <div class="container">

    <!-- Profile Info -->
    <div class="card">
      <h3>My Profile</h3>

      <div class="info"><strong>Name:</strong> <%= logginedUser.username %></div>
      <div class="info"><strong>Age:</strong> <%= logginedUser.age %></div>
      <div class="info"><strong>Gender:</strong> <%= logginedUser.gender %></div>
      <div class="info"><strong>Email:</strong> <%= logginedUser.email %></div>
      <div class="info"><strong>Problem:</strong> <%= logginedUser.problem %></div>

    </div>

    <!--Doctor Info -->
    <div class="card">
      <h3>Assigned Doctor</h3>

      <% if(logginedUser.assignedDoctor){ %>
        <div class="info"><strong>Name:</strong> <%= logginedUser.assignedDoctor.username %></div>
        <div class="info"><strong>Department:</strong> <%= logginedUser.assignedDoctor.department %></div>
      <% } else { %>
        <p>No doctor assigned</p>
      <% } %>

    </div>

    <!-- Prescription -->
    <div class="card">
      <h3>Prescription</h3>

      <% if(logginedUser.prescription){ %>
        <div class="prescription">
          <%= logginedUser.prescription %>
        </div>
      <% } else { %>
        <p>No prescription yet</p>
      <% } %>

    </div>

    <!-- Billing -->
    <div class="card">
      <h3>Billing Status</h3>

      <span class="badge 
        <%= logginedUser.billing === 'Pending' ? 'pending' : '' %>
        <%= logginedUser.billing === 'Partial' ? 'partial' : '' %>
        <%= logginedUser.billing === 'Complete' ? 'complete' : '' %>
      ">
        <%= logginedUser.billing %>
      </span>

    </div>

    <!-- 🔹 Vitals -->
    <!-- <div class="card">
      <h3>Vitals</h3>

      <% if(logginedUser.vitals){ %>
        <div class="info">Temperature: <%= logginedUser.vitals.temp %> °C</div>
        <div class="info">BP: <%= logginedUser.vitals.bp %></div>
        <div class="info">Heart Rate: <%= logginedUser.vitals.heartRate %> bpm</div>
        <div class="info">Oxygen: <%= logginedUser.vitals.oxygen %> %</div>
      <% } else { %>
        <p>No vitals recorded</p>
      <% } %>

    </div> -->

  </div>

</body>
</html>