<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Doctor Dashboard</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/doctor.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  </head>
    <nav class="navbar">
      <div class="doctor-profile">
        <div class="avatar"><i class="fa-solid fa-user-doctor"></i></div>
        <span><%=logginedUser.username%></span>
      </div>
      <a href="/user/logout" class="logout-btn">Logout</a>
    </nav>


    <main class="main-container">
      <div class="page-header">
        <h1 class="page-title">Assigned Patients</h1>
        <p class="page-subtitle">View and manage today's appointments.</p>
      </div>

       <div class="patient-grid">
      <%for(patient of Assignedpatients){%>

        <div class="patient-card">
  <div class="card-header">
    <div class="patient-info">
      <h3><%=patient.username%></h3>
      <div class="patient-details">
        <span>Age: 42</span>
        <span>Male</span>
      </div>
    </div>
    <span class="status-badge status-prescribed">Prescribed</span>
  </div>

  <div class="card-body">
    <span class="ailment">Viral Fever</span>

    <!--  PRESCRIPTION SECTION -->
    <form action="/user/add-prescription/<%= patient._id %>" method="POST">
      
      <!-- Show existing prescription if any -->
      <% if(patient.prescription){ %>
        <p style="margin-top:10px; font-size:14px;">
          <strong>Existing:</strong> <%= patient.prescription %>
        </p>
      <% } %>

      <!-- Textbox -->
      <textarea 
        name="prescription" 
        placeholder="Write prescription here..." 
        rows="5"
        style="width:100%; margin-top:10px; padding:8px; border-radius:6px; border:1px solid #ccc;"
      ></textarea>

      <!-- Save Button -->
      <button 
        type="submit" 
        style="margin-top:8px; padding:6px 12px; border:none; background:#4CAF50; color:white; border-radius:5px; cursor:pointer;"
      >
        Save Prescription
      </button>

    </form>

  </div>
</div>

      
      <%}%>  
      </div>
    </main>
  </body>
</html>
